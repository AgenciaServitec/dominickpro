---
import CheckCircle from "phosphor-astro/CheckCircle.astro";
import WhatsappLogo from "phosphor-astro/WhatsappLogo.astro";
import House from "phosphor-astro/House.astro";

import Layout from "../layouts/Layout.astro";
import ContentWidth from "../components/ContentWidth.astro";

const URL = Astro.url.pathname;
const isThankYouPage =  URL === "/gracias";
---

<Layout
        title="¡Gracias por contactarnos! | DPI"
        description="Confirmación de envío - Dominick Pro Inmobiliaria"
        image="/og-default.png"
        type="website"
        isThankYouPage={isThankYouPage}
>
    <ContentWidth>
        <div class="relative min-h-[70vh] flex flex-col items-center justify-center w-full max-w-7xl mx-auto text-center pt-36 pb-28 overflow-hidden">
            <div class="relative z-10 flex flex-col items-center animate-fade-in translate-y-4">
                <div class="mb-8 relative">
                    <div class="absolute inset-0 bg-primary-500/20 blur-3xl rounded-full"></div>
                    <div class="relative bg-white rounded-full p-1">
                        <CheckCircle class="w-20 h-20 md:w-28 md:h-28 text-primary-500" />
                    </div>
                </div>

                <div class="mb-10 max-w-lg">
                    <h2 class="text-secondary-950 text-2xl md:text-3xl font-bold mb-3">
                        ¡Tu mensaje ha sido recibido!
                    </h2>
                    <p class="text-secondary-500 text-sm md:text-base">
                        En breve, uno de nuestros asesores se pondrá en contacto contigo para brindarte toda la información que necesitas sobre tu próximo lote.
                    </p>
                </div>

                <a href="https://wa.me/51986342948?text=Hola,%20acabo%20de%20enviar%20el%20formulario%20y%20me%20gustar%C3%ADa%20agilizar%20la%20informaci%C3%B3n."
                   target="_blank"
                   class="flex items-center gap-3 text-center px-6 py-4 bg-primary-500 text-secondary-950 font-bold rounded-md uppercase text-sm"
                >
                    <WhatsappLogo class="w-6 h-6 md:w-7 md:h-7 group-hover:rotate-12 transition-transform" />
                    <span class="text-xs md:text-sm uppercase">Atención Inmediata vía WhatsApp</span>
                </a>

                <div class="flex flex-col items-center mt-10">
                    <a href="/" class="flex items-center gap-2 text-secondary-950 hover:text-secondary-900 font-bold text-[10px] md:text-xs transition-all group uppercase">
                        <House class="w-4 h-4 transition-transform group-hover:-translate-y-0.5" />
                        Regresar al Inicio
                    </a>
                </div>
            </div>
        </div>
    </ContentWidth>
</Layout>

<style>
    .animate-fade-in {
        animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>