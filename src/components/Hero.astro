---
import ContentWidth from "./ContentWidth.astro";
---

<section class="relative w-full min-h-screen flex items-center pt-28 xl:pt-24 pb-4 overflow-hidden">

  <div class="absolute inset-0 z-0 bg-secondary-950">
    <video
        autoplay
        muted
        loop
        playsinline
        class="w-full h-full object-cover animate-video-loop contrast-[1.1] brightness-[0.7]"
    >
      <source src="/bg-hero-video.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-linear-to-r from-secondary-950 via-secondary-950/40 to-transparent"></div>
  </div>

  <ContentWidth>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center relative z-10">

      <div class="space-y-10">
        <div class="space-y-6 relative z-10">
          <h1 class="text-center lg:text-left text-3xl md:text-5xl xl:text-6xl font-bold text-white">
            Tu Lote en Huaral: <br/>
            <span class="inline-block bg-logo-gradient bg-clip-text" style="-webkit-background-clip: text; -webkit-text-fill-color: transparent;">a solo 25 min del Megapuerto de Chancay</span>
          </h1>
          <p class="text-center lg:text-left text-lg max-w-xl mx-auto lg:m-0">
            Asegura tu patrimonio con lotes desde <span class="font-semibold">$12,000</span> en zonas de expansión estratégica. Títulos independizados y entrega inmediata.
          </p>
        </div>

        <div class="flex justify-center lg:justify-start flex-wrap gap-4 xl:gap-8 items-center relative z-10">
          <div class="flex items-center gap-4">
            <span class="text-lg md:text-2xl lg:text-3xl xl:text-5xl font-bold text-primary-500 drop-shadow-sm">+1600</span>
            <span class="text-xs md:text-md uppercase font-bold">Lotes <br/> entregados</span>
          </div>
          <div class="block w-1 h-12 bg-secondary-800"></div>
          <div class="flex items-center gap-4">
            <span class="text-lg md:text-2xl lg:text-3xl xl:text-5xl font-bold text-primary-500 drop-shadow-sm">12</span>
            <span class="text-xs md:text-md uppercase font-bold">Provincias <br/> con presencia</span>
          </div>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="bg-white p-4 rounded-lg shadow-2xl w-full max-w-md">
          <p class="text-secondary-900 text-center mb-8 text-md font-semibold">
            Reserva tu asesoría gratuita
          </p>

          <form id="lead-form" class="space-y-4">
            <div>
              <label for="fullName" class="block text-sm font-medium text-secondary-900 mb-2">Nombre Completo</label>
              <input
                  id="fullName"
                  name="fullName"
                  type="text"
                  placeholder="Tu nombre"
                  class="w-full px-4 py-3 bg-secondary-50 border border-secondary-100 rounded-md text-secondary-900 focus:outline-none focus:border-2 focus:border-primary-500 placeholder:text-secondary-400 transition-colors"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-secondary-900 mb-2">Correo Electrónco</label>
              <input
                  id="email"
                  name="email"
                  type="tel"
                  placeholder="ejemplo@correo.com"
                  class="w-full px-4 py-3 bg-secondary-50 border border-secondary-100 rounded-md text-secondary-900 focus:outline-none focus:border-2 focus:border-primary-500 placeholder:text-secondary-400 transition-colors"
              />
            </div>

            <div>
              <label for="whatsapp" class="block text-sm font-medium text-secondary-900 mb-2">WhatsApp</label>
              <input
                  id="whatsapp"
                  name="whatsapp"
                  type="tel"
                  placeholder="+51 900 000 000"
                  class="w-full px-4 py-3 bg-secondary-50 border border-secondary-100 rounded-md text-secondary-900 focus:outline-none focus:border-2 focus:border-primary-500 placeholder:text-secondary-400 transition-colors"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-secondary-900 mb-2">Mensaje</label>
              <textarea
                  id="message"
                  name="message"
                  placeholder="Hola, me interesa el proyecto de Huaral. Quisiera más información sobre los lotes disponibles..."
                  class="w-full px-4 py-3 bg-secondary-50 border border-secondary-100 rounded-md text-secondary-900 focus:outline-none focus:border-2 focus:border-primary-500 placeholder:text-secondary-400 transition-colors"
                  rows="3"
              />
            </div>

            <button
                id="submit-btn"
                type="submit"
                class="w-full bg-primary-500 hover:bg-primary-400 text-secondary-950 font-bold text-sm py-4 rounded-md transition-all transform hover:scale-[1.05] active:scale-[0.95] shadow-[0_10px_20px_-10px_rgba(255,187,0,0.4)] uppercase animate-soft-pulse cursor-pointer"
            >
              <span id="btn-text">Asegurar mi Asesoría Gratuita</span>
            </button>
          </form>
        </div>
      </div>

    </div>
  </ContentWidth>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!submitBtn || !btnText) return;

    submitBtn.disabled = true;
    btnText.textContent = 'Enviando solicitud...';

    const formData = new FormData(form);

    const entryPayload = {
      category: "contact",
      hostname: "proyecto-inmobiliario-dpi.com",
      message: formData.get('message') || "Interés en Lotes Huaral",
      subject: "Nueva solicitud de lote - Web Huaral",
      client: {
        fullName: formData.get('fullName'),
        email: formData.get('email'),
        phone: {
          prefix: "+51",
          number: formData.get('whatsapp'),
        }
      },
    };

    try {
      const response = await fetch("https://api-servitec-peru.web.app/entries/contact", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(entryPayload),
      });

      const result = await response.json();

      if (!response.ok) {
        console.error("Error de validación:", result.details);
        throw new Error(result.error || "Error al procesar la data.");
      }

      form.reset();
      window.location.href = "/gracias";

    } catch (error) {
      console.error("Error detallado:", error);
      alert("Hubo un problema al enviar tu mensaje. Por favor intenta nuevamente.");

      submitBtn.disabled = false;
      btnText.textContent = 'Asegurar mi Asesoría Gratuita';
    }
  });
</script>