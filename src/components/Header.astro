---
import { Image } from 'astro:assets';
import List from "phosphor-astro/List.astro";
import X from "phosphor-astro/X.astro";

import ContentWidth from "./ContentWidth.astro";
---

<header
    id="header"
    class="w-full fixed top-0 left-0 z-50 transition-all duration-300 border-b border-transparent bg-transparent py-4"
>
  <ContentWidth>
    <div class="flex justify-between items-center h-16 md:h-20">

      <div class="flex items-center gap-12">
        <a href="/" class="shrink-0 transition-transform hover:scale-105">
          <Image src="/logo.png" alt="Logo de Dominick Pro Inmobiliaria" width="120" height="120" />
        </a>

        <nav class="hidden md:block">
          <ul class="flex gap-8 text-sm font-medium">
            <li>
              <a href="/#lotes-disponibles" class="text-white hover:text-primary-400 transition-colors nav-link">Lotes Disponibles</a>
            </li>
            <li>
              <a href="/#nosotros" class="text-white hover:text-primary-400 transition-colors nav-link">Nosotros</a>
            </li>
            <li>
              <a href="/#servicios" class="text-white hover:text-primary-400 transition-colors nav-link">Servicios</a>
            </li>
            <li>
              <a href="/#ubicacion" class="text-white hover:text-primary-400 transition-colors nav-link">Ubicación</a>
            </li>
          </ul>
        </nav>
      </div>

      <button id="open-menu" class="bg-secondary-950 p-1 rounded-md md:hidden">
        <List class="w-8 h-8 text-primary-500" />
      </button>

      <div class="hidden lg:flex items-center">
        <a
            href="https://wa.me/51986342948?text=Hola,%20me%20interesa%20obtener%20informaci%C3%B3n%20sobre%20los%20lotes%20disponibles."
            class="px-6 py-2.5 bg-primary-500 hover:bg-primary-400 text-secondary-950 font-bold text-sm rounded-md transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-[0_10px_20px_-10px_rgba(255,187,0,0.3)] mt-4 uppercase"
            target="_blank"
        >
          Consultar Ahora
        </a>
      </div>

    </div>
  </ContentWidth>
</header>

<dialog
    id="mobile-menu"
    class="m-0 h-screen max-h-none w-[85%] max-w-87.5 bg-secondary-950 p-0 text-white backdrop:bg-black/50 backdrop:backdrop-blur-sm shadow-2xl"
>
  <div class="flex flex-col h-full p-4">
    <div class="flex justify-between items-center mb-12">
      <Image src="/logo.png" alt="Logo" width="100" height="100" />
      <button id="close-menu" class="">
        <X class="w-8 h-8 text-primary-500" />
      </button>
    </div>

    <nav>
      <ul class="flex flex-col gap-6 text-xl font-semibold">
        <li><a href="/#lotes-disponibles" class="mobile-nav-link block py-2 border-b border-white/5">Lotes Disponibles</a></li>
        <li><a href="/#nosotros" class="mobile-nav-link block py-2 border-b border-white/5">Nosotros</a></li>
        <li><a href="/#servicios" class="mobile-nav-link block py-2 border-b border-white/5">Servicios</a></li>
        <li><a href="/#ubicacion" class="mobile-nav-link block py-2 border-b border-white/5">Ubicación</a></li>
      </ul>
    </nav>

    <div class="mt-auto pb-14">
      <a href="/#consultar" class="mobile-nav-link block w-full text-center px-6 py-4 bg-primary-500 text-secondary-950 font-bold rounded-md uppercase text-sm">
        Consultar Ahora
      </a>
    </div>
  </div>
</dialog>

<script>
  const header = document.querySelector('#header') as HTMLElement;
  const dialog = document.querySelector('#mobile-menu') as HTMLDialogElement;
  const openBtn = document.querySelector('#open-menu');
  const closeBtn = document.querySelector('#close-menu');
  const navLinks = document.querySelectorAll('.mobile-nav-link');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header.classList.add('bg-secondary-950/95', 'backdrop-blur-md', 'border-secondary-800', 'shadow-2xl');
      header.classList.remove('border-transparent', 'bg-transparent');
    } else {
      header.classList.remove('bg-secondary-950/95', 'backdrop-blur-md', 'border-secondary-800', 'shadow-2xl');
      header.classList.add('border-transparent', 'bg-transparent');
    }
  });

  openBtn?.addEventListener('click', () => {
    dialog.showModal();
    document.body.style.overflow = 'hidden';
  });

  const closeDialog = () => {
    dialog.classList.add('hide');

    dialog.addEventListener('animationend', function handler() {
      dialog.classList.remove('hide');
      dialog.close();
      document.body.style.overflow = '';

      dialog.removeEventListener('animationend', handler);
    }, { once: true });
  };

  closeBtn?.addEventListener('click', closeDialog);

  navLinks.forEach(link => {
    link.addEventListener('click', closeDialog);
  });

  dialog.addEventListener('click', (e) => {
    const dialogDimensions = dialog.getBoundingClientRect();
    if (
        e.clientX < dialogDimensions.left ||
        e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top ||
        e.clientY > dialogDimensions.bottom
    ) {
      closeDialog();
    }
  });
</script>

<style>
  .nav-link {
    position: relative;
    padding-bottom: 4px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 0;
    background-color: var(--color-primary-500);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  dialog {
    position: fixed;
    left: auto;
    right: 0;
    top: 0;
  }

  dialog[open] {
    animation: slide-from-right 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  dialog.hide {
    animation: slide-to-right 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  dialog.hide::backdrop {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  @keyframes slide-from-right {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }

  @keyframes slide-to-right {
    from { transform: translateX(0); }
    to { transform: translateX(100%); }
  }
</style>