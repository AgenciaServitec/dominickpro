---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import '@fontsource-variable/geist/wght.css';
import "../styles/global.css";
import WhatsappBtn from "../components/WhatsappBtn.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: "website" | "article";
  siteName?: string;
  twitterCard?: "summary" | "summary_large_image";
  twitterSite?: string;
  robots?: string;
  canonical?: string;
  gtmId?: string;
  isThankYouPage?: boolean;
}

const {
  title = "Lotes en Huaral y Alquileres en Lima",
  description = "Invierta en lotes en Huaral a 25 min del Megapuerto de Chancay. Seguridad jurídica 100% con títulos inscritos en SUNARP. +1600 lotes vendidos.",
  image = "/og-default.png",
  url = Astro.url.href,
  type = "website",
  siteName = "Dominick Pro Inmobiliaria",
  twitterCard = "summary_large_image",
  twitterSite = "",
  robots = "index, follow",
  canonical,
  gtmId = "GTM-M6GH3T2F",
  isThankYouPage = false
} = Astro.props;

const siteUrl = Astro.site? new URL(url, Astro.site).href : url;
const absoluteImage = Astro.site? new URL(image, Astro.site).href : image;
const absoluteCanonical = canonical || siteUrl;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": siteName,
  "image": absoluteImage,
  "telephone": "+51 986 342 948",
  "url": siteUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Juan del Carpio 195",
    "addressLocality": "San Isidro",
    "addressRegion": "Lima",
    "addressCountry": "PE"
  },
  "priceRange": "$12,000 - $35,000",
  "areaServed": ["Huaral", "Chancay", "Lima", "Carabayllo"]
};
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />

  <!-- Google Tag Manager -->
  <script is:inline define:vars={{ gtmId }}>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer', gtmId);
  </script>
  <!-- End Google Tag Manager -->

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={absoluteCanonical} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteImage} />
  <meta property="og:url" content={url} />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="es_PE" />

  <meta name="twitter:card" content={twitterCard} />
  <meta name="twitter:site" content={twitterSite} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteImage} />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

</head>
<body class="antialiased scroll-smooth relative text-white min-h-screen flex flex-col overflow-x-hidden">
<!-- Google Tag Manager (noscript) -->
<noscript>
  <iframe
      src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
      height="0"
      width="0"
      style="display:none;visibility:hidden"
  ></iframe>
</noscript>
<!-- End Google Tag Manager (noscript) -->

<Header isThankYouPage={isThankYouPage} />

<main class="flex-1">
  <slot />
</main>

<Footer />

<WhatsappBtn/>
</body>
</html>

<style is:global>
  :root {
    --primary-neon: #FFBF00;
    --secondary-neon: #D4FF00;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #0a0a0a;
  }
  ::-webkit-scrollbar-thumb {
    background: #262626;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--primary-neon);
  }

  main {
    animation: fadeIn 0.6s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>