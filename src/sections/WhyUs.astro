---
import ShieldCheck from "phosphor-astro/ShieldCheck.astro";
import SealCheck from "phosphor-astro/SealCheck.astro";

import ContentWidth from "../components/ContentWidth.astro";

const highlights = {
    main: {
        title: "¿Por qué elegirnos?",
        description: "Nuestra metodología combina análisis de mercado avanzado con una atención personalizada para asegurar tu éxito financiero.",
        bgImage: "/image-whyus.png"
    },
    security: {
        title: "Seguridad Jurídica",
        description: "Transparencia absoluta en cada proceso legal y contractual.",
        icon: ShieldCheck
    },
    support: {
        title: "Asesoría 24/7",
        description: "Estamos siempre disponibles para resolver tus dudas durante el proceso de inversión.",
    },
    certification: {
        title: "Certificación Inmobiliaria",
        description: "Registrados oficialmente ante el Ministerio de Vivienda para tu total tranquilidad.",
        icon: SealCheck
    }
}


---

<section class="w-full py-20 bg-white">
    <ContentWidth>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:auto-rows-[280px]">

            <div class="md:col-span-2 relative overflow-hidden rounded-lg bg-secondary-900 flex items-end p-8 md:p-12 group">
                <div class="absolute inset-0 bg-linear-to-t from-secondary-950 via-secondary-900/60 to-transparent z-10"></div>

                <div class="absolute inset-0 scale-105 group-hover:scale-100 transition-transform duration-700 opacity-50">
                    <img src="/image-whyus.png" alt="Edificio moderno" class="w-full h-full object-cover" />
                </div>

                <div class="relative z-20 max-w-md">
                    <h2 class="text-white text-3xl md:text-4xl font-semibold mb-4">
                        {highlights.main.title}
                    </h2>
                    <p class="text-secondary-300 text-sm md:text-base">
                        {highlights.main.description}
                    </p>
                </div>
            </div>

            <div class="bg-primary-500 rounded-lg p-8 flex flex-col items-center justify-center text-center group transition-colors hover:bg-[#FFBF00]">
                <div class="mb-6 text-secondary-900">
                    <highlights.security.icon class="w-12 h-12" />
                </div>
                <h3 class="text-secondary-900 font-bold text-lg mb-2">{highlights.security.title}</h3>
                <p class="text-secondary-900/80 text-sm md:text-base">
                    {highlights.security.description}
                </p>
            </div>

            <div class="bg-white border border-secondary-100 rounded-lg p-8 flex flex-col justify-center">
                <span class="text-secondary-950 font-bold text-lg mb-4">
                    {highlights.support.title}
                </span>
                <p class="text-secondary-500 text-sm md:text-base">
                    {highlights.support.description}
                </p>
            </div>

            <div class="md:col-span-2 bg-secondary-50 rounded-lg p-8 md:p-12 flex items-center gap-8">
                <div class="hidden sm:flex shrink-0 w-20 h-20 items-center justify-center text-[#8B7330]">
                    <highlights.certification.icon class="w-16 h-16" />
                </div>
                <div>
                    <h3 class="text-secondary-950 font-bold text-lg mb-2">{highlights.certification.title}</h3>
                    <p class="text-secondary-500 text-sm md:text-base">
                        {highlights.certification.description}
                    </p>
                </div>
            </div>

        </div>
    </ContentWidth>
</section>